PORT=8000

# OPENAI - required for the current ingestion + timeline pipeline
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60
TIMELINE_LOCAL_MODEL=gpt-4o-mini
TIMELINE_MERGE_MODEL=gpt-4.1
TIMELINE_CHAPTER_CONCURRENCY=6
TIMELINE_LOCAL_TIMEOUT_SECONDS=25
TIMELINE_MERGE_TIMEOUT_SECONDS=45
TIMELINE_MAX_EVENTS_PER_CHAPTER=4

# FOUNDRY - not used by the current branch, kept for the later switch-back
PROJECT_KEY=
PROJECT_ENDPOINT=
OPENAI_ENDPOINT=

# COSMOSDB - required
COSMOS_ACCOUNT_URL=
COSMOS_KEY=
COSMOS_DATABASE=
COSMOS_CONTAINER=

# GREMLIN - optional for timeline branch
GREMLIN_ENDPOINT=
GREMLIN_KEY=
GREMLIN_DATABASE=
GREMLIN_GRAPH=

# AZURE BLOB STORAGE - required
AZURE_BLOB_CONTAINER=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=

# Frontend
FRONTEND_ORIGIN="http://localhost:5173"
