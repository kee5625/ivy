# Neon Database
# Get this from Neon dashboard -> Connect -> Pooled connection string
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require

# Redis (for job progress pub/sub)
# Local: redis://localhost:6379
# Production: rediss://default:pass@host.upstash.io:6379
REDIS_URL=redis://localhost:6379

# S3/MinIO (for PDF storage)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ivy-pdfs
S3_REGION=us-east-1

# OpenAI (LLM provider)
OPENAI_API_KEY=sk-...

# Optional: LangGraph checkpoint config (defaults to DATABASE_URL)
# LANGGRAPH_CHECKPOINT_POSTGRES_URI=${DATABASE_URL}

# Optional: Model overrides
# TIMELINE_LOCAL_MODEL=gpt-4o-mini
# TIMELINE_MERGE_MODEL=gpt-4.1
# PLOT_HOLE_MODEL=gpt-4o-mini
